# Ścieżka względna do katalogu prisma/ — plik: data/cashflow.db w katalogu projektu
DATABASE_URL="file:../data/cashflow.db"

# KSeF — Stage 1B: stub domyślnie; realne API po ustawieniu KSEF_DATA_SOURCE=api + KSEF_ACCESS_TOKEN
KSEF_ENABLED=true
KSEF_ENVIRONMENT=test
# Bazowy URL z /v2, np. https://api-test.ksef.mf.gov.pl/v2 (puste = domyślny host testowy)
KSEF_API_BASE_URL=
# stub | api — przy api wymagany jest KSEF_ACCESS_TOKEN (JWT z sesji uwierzytelnienia KSeF)
KSEF_DATA_SOURCE=stub
# JWT Bearer — uzyskany poza aplikacją (np. po redeem tokenu); nie commituj wartości
KSEF_ACCESS_TOKEN=
# Subject2 = faktury, gdzie podmiot jest nabywcą (typowe „skrzynka” zakupowa)
KSEF_QUERY_SUBJECT_TYPE=Subject2
# Zakres dat wstecz dla POST /invoices/query/metadata (max. ~93 dni — limit API)
KSEF_SYNC_LOOKBACK_DAYS=90
