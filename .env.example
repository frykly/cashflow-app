# Ścieżka względna do katalogu prisma/ — plik: data/cashflow.db w katalogu projektu
DATABASE_URL="file:../data/cashflow.db"

# Auth — sekret do podpisywania sesji (JWT w cookie); min. 32 znaki, losowy
AUTH_SECRET=

# Tworzenie konta admina — npm run create-admin (hasło min. 10 znaków)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# KSeF — stub domyślnie; realne API po KSEF_DATA_SOURCE=api + KSEF_KSEF_TOKEN + KSEF_COMPANY_TAX_ID
KSEF_ENABLED=true
KSEF_ENVIRONMENT=test
# Bazowy URL z /v2 — MUSI pasować do środowiska, w którym wygenerowano token:
# test (TR): https://api-test.ksef.mf.gov.pl/v2
# demo:       https://api-demo.ksef.mf.gov.pl/v2
# produkcja:  https://api.ksef.mf.gov.pl/v2
KSEF_API_BASE_URL=
# stub | api — przy api wymagany KSEF_KSEF_TOKEN (token z Aplikacji Podatnika / MCU)
KSEF_DATA_SOURCE=stub
# Token KSeF z Aplikacji Podatnika — NIE wklejać jako Bearer; aplikacja wymienia go na JWT accessToken
KSEF_KSEF_TOKEN=
# Przestarzałe — użyj KSEF_KSEF_TOKEN; jeśli ustawione bez KSEF_KSEF_TOKEN, traktowane jako token MCU (migracja)
# KSEF_ACCESS_TOKEN=
# Sync metadata: domyślnie Subject1+Subject2 (kosztowe i przychodowe). Override:
# KSEF_QUERY_SUBJECT_TYPES=Subject1,Subject2
# KSEF_QUERY_SUBJECT_TYPE=Subject2   # tylko jeden kierunek
# KSEF_QUERY_SUBJECT_TYPE=BOTH         # to samo co domyślne
# Zakres dat wstecz dla POST /invoices/query/metadata (max. ~93 dni — limit API)
KSEF_SYNC_LOOKBACK_DAYS=90
# NIP własnej firmy (cyfry) — klasyfikacja zakup vs sprzedaż + kontekst uwierzytelnienia KSeF
KSEF_COMPANY_TAX_ID=
