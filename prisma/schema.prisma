generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AppSettings {
  id                 Int      @id @default(1)
  mainOpeningBalance Decimal
  vatOpeningBalance  Decimal
  effectiveFrom      DateTime
  updatedAt          DateTime @updatedAt
}

/// Ręczna kontrola sald bankowych vs prognoza (dzień kalendarzowy = dayKey jak w ForecastDayRow).
model DailyCashReconciliation {
  id              String   @id @default(cuid())
  dayKey          String   @unique
  mainBankBalance Decimal
  vatBankBalance  Decimal
  /// MATCHED — zgodne w tolerancji; NEEDS_REVIEW — różnica poza tolerancją
  status          String
  note            String   @default("")
  /// Ręczne potwierdzenie zgodności z wyciągiem — nie wpływa na kolor dnia (rozliczenia).
  mainChecked     Boolean  @default(false)
  vatChecked      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Project {
  id                 String                   @id @default(cuid())
  name               String
  code               String?
  clientName         String?
  description        String?
  isActive           Boolean                  @default(true)
  /// NEW | IN_PROGRESS | FOR_HANDOFF | COMPLETED
  lifecycleStatus    String?
  /// NONE | TO_SETTLE | WAITING_FOR_SETTLEMENT | DPW_TODO | SETTLED | SETTLED_WITH_GAPS | SETTLED_BLOCKED
  settlementStatus   String?
  plannedRevenueNet  Decimal?
  plannedCostNet     Decimal?
  startDate          DateTime?
  endDate            DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  costInvoices       CostInvoice[]
  incomeInvoices     IncomeInvoice[]
  plannedEvents      PlannedFinancialEvent[]
  costAllocations    CostInvoiceProjectAllocation[]
  incomeAllocations  IncomeInvoiceProjectAllocation[]
  plannedAllocations PlannedEventProjectAllocation[]
  costPaymentProjectAllocations   CostInvoicePaymentProjectAllocation[]
  incomePaymentProjectAllocations IncomeInvoicePaymentProjectAllocation[]
  otherIncomes       OtherIncome[]
  missingItems       ProjectMissingItem[]
  tasks              ProjectTask[]
}

/// Zadania operacyjne projektu (bez powiązania z cashflow / zdarzeniami planowanymi).
model ProjectTask {
  id               String    @id @default(cuid())
  projectId        String
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  plannedStartDate DateTime?
  plannedEndDate   DateTime?
  assigneeName     String?
  /// TODO | IN_PROGRESS | DONE
  status           String    @default("TODO")
  isDone           Boolean   @default(false)
  doneAt           DateTime?
  /// LOW | NORMAL | HIGH
  priority         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([projectId])
}

/// Słownik statusu realizacji projektu — `Project.lifecycleStatus` przechowuje `slug`.
model ProjectLifecycleStatusOption {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Słownik statusu rozliczenia projektu — `Project.settlementStatus` przechowuje `slug`.
model ProjectSettlementStatusOption {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Typ „braku” projektu (wielokrotny wybór przez ProjectMissingItem).
model ProjectMissingTypeOption {
  id           String               @id @default(cuid())
  name         String
  slug         String               @unique
  sortOrder    Int                  @default(0)
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  missingItems ProjectMissingItem[]
}

model ProjectMissingItem {
  id            String                   @id @default(cuid())
  projectId     String
  project       Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  missingTypeId String
  missingType   ProjectMissingTypeOption @relation(fields: [missingTypeId], references: [id], onDelete: Restrict)
  createdAt     DateTime                 @default(now())

  @@unique([projectId, missingTypeId])
  @@index([projectId])
  @@index([missingTypeId])
}

/// Rozbicie kosztu na wiele projektów — jeśli są wiersze, raportowanie używa ich zamiast legacy CostInvoice.projectId.
model CostInvoiceProjectAllocation {
  id            String      @id @default(cuid())
  costInvoiceId String
  costInvoice   CostInvoice @relation(fields: [costInvoiceId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Restrict)
  netAmount     Decimal
  grossAmount   Decimal
  description   String      @default("")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([costInvoiceId])
  @@index([projectId])
}

/// Rozbicie przychodu na wiele projektów — jeśli są wiersze, raportowanie używa ich zamiast legacy IncomeInvoice.projectId.
model IncomeInvoiceProjectAllocation {
  id              String        @id @default(cuid())
  incomeInvoiceId String
  incomeInvoice   IncomeInvoice @relation(fields: [incomeInvoiceId], references: [id], onDelete: Cascade)
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Restrict)
  netAmount       Decimal
  grossAmount     Decimal
  description     String        @default("")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([incomeInvoiceId])
  @@index([projectId])
}

/// Rozbicie zdarzenia planowanego na wiele projektów — kwoty jak w PlannedFinancialEvent (amount + amountVat).
model PlannedEventProjectAllocation {
  id                      String                @id @default(cuid())
  plannedFinancialEventId String
  plannedFinancialEvent   PlannedFinancialEvent @relation(fields: [plannedFinancialEventId], references: [id], onDelete: Cascade)
  projectId               String
  project                 Project               @relation(fields: [projectId], references: [id], onDelete: Restrict)
  amount                  Decimal
  amountVat               Decimal               @default(0)
  description             String                @default("")
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  @@index([plannedFinancialEventId])
  @@index([projectId])
}

model IncomeCategory {
  id                 String                  @id @default(cuid())
  name               String
  slug               String                  @unique
  invoices           IncomeInvoice[]
  otherIncomes       OtherIncome[]
  plannedAsIncome    PlannedFinancialEvent[] @relation("PlannedIncomeCategory")
  recurringTemplates RecurringTemplate[]     @relation("RecurringIncomeCategory")
}

/// Przychód poza fakturą (np. zwrot podatku, wpłata własna). Rozdział MAIN/VAT przez vatAmount (bez netto w MVP).
model OtherIncome {
  id                String          @id @default(cuid())
  amountGross       Decimal
  vatAmount         Decimal         @default(0)
  date              DateTime
  description       String
  projectId         String?
  project           Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  categoryId        String?
  category          IncomeCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  source            String
  bankTransactionId String?         @unique
  bankTransaction   BankTransaction? @relation(fields: [bankTransactionId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())

  @@index([date])
  @@index([projectId])
}

model ExpenseCategory {
  id                 String                  @id @default(cuid())
  name               String
  slug               String                  @unique
  /// false = zarchiwizowana — ukryta przy nowych wpisach, widoczna przy starych rekordach
  isActive           Boolean                 @default(true)
  invoices           CostInvoice[]
  plannedAsExpense   PlannedFinancialEvent[] @relation("PlannedExpenseCategory")
  recurringTemplates RecurringTemplate[]     @relation("RecurringExpenseCategory")
}

model Contractor {
  id             String            @id @default(cuid())
  displayName    String
  normalizedName String
  taxId          String?
  type           String?
  notes          String?
  aliases        ContractorAlias[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([normalizedName])
  @@index([taxId])
}

model ContractorAlias {
  id              String     @id @default(cuid())
  contractorId    String
  contractor      Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  aliasName       String
  normalizedAlias String
  source          String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([contractorId])
  @@index([normalizedAlias])
}

model IncomeInvoice {
  id                 String   @id @default(cuid())
  invoiceNumber      String
  contractor         String
  description        String   @default("")
  vatRate            Int      @default(23) // 0 | 8 | 23
  netAmount          Decimal
  vatAmount          Decimal
  grossAmount        Decimal
  issueDate          DateTime
  paymentDueDate     DateTime
  plannedIncomeDate  DateTime
  status             String // PLANOWANA | WYSTAWIONA | PARTIALLY_RECEIVED | OPLACONA
  vatDestination     String // MAIN | VAT
  confirmedIncome    Boolean  @default(false)
  actualIncomeDate   DateTime?
  notes              String   @default("")
  projectName        String?
  projectId          String?
  project            Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  incomeCategoryId   String?
  incomeCategory     IncomeCategory? @relation(fields: [incomeCategoryId], references: [id], onDelete: SetNull)
  payments           IncomeInvoicePayment[]
  sourceRecurringTemplateId String?
  generatedOccurrenceDate   DateTime?
  isGeneratedFromRecurring  Boolean  @default(false)
  isRecurringDetached       Boolean  @default(false)
  sourceRecurringTemplate   RecurringTemplate? @relation("RecurringGeneratedIncome", fields: [sourceRecurringTemplateId], references: [id], onDelete: SetNull)
  linkedFromPlannedEvent    PlannedFinancialEvent? @relation("PlannedConvertedToIncome")
  projectAllocations IncomeInvoiceProjectAllocation[]
  /// Harmonogram planowanych wpłat (MAIN/VAT) — nie są to rzeczywiste wpłaty (`payments`).
  plannedPayments    IncomeInvoicePlannedPayment[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([sourceRecurringTemplateId])
  @@index([generatedOccurrenceDate])
  @@index([projectId])
}

/// Plan wpłat na fakturze (termin + podział MAIN/VAT) — informacyjnie, bez powiązania z realnymi wpłatami.
model IncomeInvoicePlannedPayment {
  id                  String        @id @default(cuid())
  incomeInvoiceId     String
  incomeInvoice       IncomeInvoice @relation(fields: [incomeInvoiceId], references: [id], onDelete: Cascade)
  dueDate             DateTime
  plannedMainAmount   Decimal
  plannedVatAmount    Decimal
  note                String        @default("")
  sortOrder           Int           @default(0)
  /// PLANNED | DONE | CANCELLED
  status              String        @default("PLANNED")
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([incomeInvoiceId])
}

model IncomeInvoicePayment {
  id                 String           @id @default(cuid())
  incomeInvoiceId    String
  incomeInvoice      IncomeInvoice    @relation(fields: [incomeInvoiceId], references: [id], onDelete: Cascade)
  amountGross        Decimal
  /// Ręczny podział kwoty brutto wpłaty na cashflow MAIN (netto) — tylko razem z allocatedVatAmount; null = proporcje z faktury.
  allocatedMainAmount Decimal?
  /// Ręczny podział na konto VAT; null = proporcje z faktury.
  allocatedVatAmount  Decimal?
  paymentDate        DateTime
  notes              String           @default("")
  /// Powiązanie z wierszem importu bankowego (wiele wpłat może dzielić jedną linię — suma ≤ kwota transakcji)
  bankTransactionId  String?
  createdAt          DateTime         @default(now())
  projectAllocations IncomeInvoicePaymentProjectAllocation[]

  @@index([bankTransactionId])
}

/// Rozbicie kwoty brutto płatności przychodu na projekty — pierwszeństwo przy raportowaniu „zapłacono”; brak wierszy = fallback wg alokacji dokumentu.
model IncomeInvoicePaymentProjectAllocation {
  id                     String               @id @default(cuid())
  incomeInvoicePaymentId String
  incomeInvoicePayment   IncomeInvoicePayment @relation(fields: [incomeInvoicePaymentId], references: [id], onDelete: Cascade)
  projectId              String
  project                Project              @relation(fields: [projectId], references: [id], onDelete: Restrict)
  grossAmount            Decimal
  description            String               @default("")
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([incomeInvoicePaymentId])
  @@index([projectId])
}

model CostInvoice {
  id                 String   @id @default(cuid())
  documentNumber     String
  supplier           String
  description        String   @default("")
  vatRate            Int      @default(23) // 0 | 8 | 23
  netAmount          Decimal
  vatAmount          Decimal
  grossAmount        Decimal
  documentDate       DateTime
  paymentDueDate     DateTime
  plannedPaymentDate DateTime
  status             String // PLANOWANA | DO_ZAPLATY | PARTIALLY_PAID | ZAPLACONA
  paid               Boolean  @default(false)
  actualPaymentDate  DateTime?
  paymentSource      String // MAIN | VAT | VAT_THEN_MAIN
  notes              String   @default("")
  projectName        String?
  projectId          String?
  project            Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  expenseCategoryId  String?
  expenseCategory    ExpenseCategory? @relation(fields: [expenseCategoryId], references: [id], onDelete: SetNull)
  payments           CostInvoicePayment[]
  sourceRecurringTemplateId String?
  generatedOccurrenceDate   DateTime?
  isGeneratedFromRecurring  Boolean  @default(false)
  isRecurringDetached       Boolean  @default(false)
  sourceRecurringTemplate   RecurringTemplate? @relation("RecurringGeneratedCost", fields: [sourceRecurringTemplateId], references: [id], onDelete: SetNull)
  linkedFromPlannedEvent    PlannedFinancialEvent? @relation("PlannedConvertedToCost")
  projectAllocations CostInvoiceProjectAllocation[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([sourceRecurringTemplateId])
  @@index([generatedOccurrenceDate])
  @@index([projectId])
}

model CostInvoicePayment {
  id                 String      @id @default(cuid())
  costInvoiceId      String
  costInvoice        CostInvoice @relation(fields: [costInvoiceId], references: [id], onDelete: Cascade)
  amountGross        Decimal
  paymentDate        DateTime
  notes              String      @default("")
  /// Wiele płatności może dzielić jedną linię banku — suma ≤ kwota transakcji
  bankTransactionId  String?
  createdAt          DateTime    @default(now())
  projectAllocations CostInvoicePaymentProjectAllocation[]

  @@index([bankTransactionId])
}

/// Rozbicie kwoty brutto płatności kosztu na projekty — pierwszeństwo przy raportowaniu „zapłacono”; brak wierszy = fallback wg alokacji dokumentu.
model CostInvoicePaymentProjectAllocation {
  id                   String             @id @default(cuid())
  costInvoicePaymentId String
  costInvoicePayment   CostInvoicePayment @relation(fields: [costInvoicePaymentId], references: [id], onDelete: Cascade)
  projectId            String
  project              Project            @relation(fields: [projectId], references: [id], onDelete: Restrict)
  grossAmount          Decimal
  description          String             @default("")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([costInvoicePaymentId])
  @@index([projectId])
}

model RecurringTemplate {
  id                String   @id @default(cuid())
  title             String
  type              String // INCOME | EXPENSE
  // accountMode: MAIN | VAT | SPLIT
  accountMode       String   @default("MAIN")
  amount            Decimal
  // amountVat: tylko SPLIT (VAT-only używa pola amount)
  amountVat         Decimal?
  incomeCategoryId  String?
  expenseCategoryId String?
  incomeCategory    IncomeCategory? @relation("RecurringIncomeCategory", fields: [incomeCategoryId], references: [id], onDelete: SetNull)
  expenseCategory   ExpenseCategory? @relation("RecurringExpenseCategory", fields: [expenseCategoryId], references: [id], onDelete: SetNull)
  frequency         String // WEEKLY | MONTHLY | QUARTERLY | YEARLY
  startDate         DateTime
  endDate           DateTime?
  dayOfMonth        Int?
  weekday           Int?
  notes             String   @default("")
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  generatedCostInvoices   CostInvoice[]           @relation("RecurringGeneratedCost")
  generatedIncomeInvoices IncomeInvoice[]         @relation("RecurringGeneratedIncome")
}

model PlannedFinancialEvent {
  id                  String             @id @default(cuid())
  type                String // INCOME | EXPENSE
  title               String
  description         String             @default("")
  amount              Decimal
  // amountVat: część VAT (0 = legacy)
  amountVat           Decimal            @default(0)
  plannedDate         DateTime
  /// PLANNED | DONE | CANCELLED | CONVERTED (CONVERTED ustawiane przy konwersji na fakturę)
  status              String
  notes               String             @default("")
  projectName         String?
  projectId           String?
  project             Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  incomeCategoryId    String?
  expenseCategoryId   String?
  incomeCategory      IncomeCategory?    @relation("PlannedIncomeCategory", fields: [incomeCategoryId], references: [id], onDelete: SetNull)
  expenseCategory     ExpenseCategory?   @relation("PlannedExpenseCategory", fields: [expenseCategoryId], references: [id], onDelete: SetNull)
  convertedToIncomeInvoiceId String?    @unique
  convertedToCostInvoiceId   String?    @unique
  convertedAt         DateTime?
  convertedToIncomeInvoice IncomeInvoice? @relation("PlannedConvertedToIncome", fields: [convertedToIncomeInvoiceId], references: [id], onDelete: SetNull)
  convertedToCostInvoice   CostInvoice?   @relation("PlannedConvertedToCost", fields: [convertedToCostInvoiceId], references: [id], onDelete: SetNull)
  projectAllocations  PlannedEventProjectAllocation[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([projectId])
}

/// Import wyciągu bankowego (CSV) — warstwa uzgodnień, bez wpływu na cashflow.
model BankImport {
  id               String            @id @default(cuid())
  fileName         String
  /// Pominięte wiersze (duplikaty itd.) — `JSON.stringify(BankImportSkippedDetail[])`; null = import sprzed zapisu.
  skippedLinesJson String?
  createdAt        DateTime          @default(now())
  transactions     BankTransaction[]
}

model BankTransaction {
  id                  String     @id @default(cuid())
  importId            String
  import              BankImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  bookingDate         DateTime
  valueDate           DateTime?
  amount              Int // grosze
  currency            String
  description         String
  counterpartyName    String?
  counterpartyAccount String?
  accountType         String // MAIN | VAT
  /// NEW | MATCHED | LINKED_COST | LINKED_INCOME | LINKED_OTHER_INCOME | TRANSFER | VAT_TOPUP | IGNORED | DUPLICATE | BROKEN_LINK | CREATED (legacy)
  status              String
  createdAt           DateTime   @default(now())
  matchedInvoiceId    String?
  linkedCostInvoiceId String?
  createdCostId       String?
  /// Unikalny fingerprint wiersza — deduplikacja przy imporcie (null = legacy)
  dedupeKey           String?    @unique
  /// Surowy materiał wejściowy do fingerprintu (np. pełne „Dane operacji” iPKO) — diagnostyka; tylko nowe importy
  dedupeInputText     String?
  otherIncome         OtherIncome?

  @@index([importId])
  @@index([status])
}

/// Staging dokumentów KSeF (etap 1 — bez powiązań z fakturami domenowymi).
model KsefSyncSession {
  id          String    @id @default(cuid())
  status      String // RUNNING | SUCCEEDED | FAILED
  environment String    @default("test")
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  message     String?
  documents   KsefDocument[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model KsefDocument {
  id                         String    @id @default(cuid())
  ksefId                     String    @unique
  source                     String // MOCK | KSEF
  status                     String
  documentType               String
  issueDate                  DateTime
  saleDate                   DateTime?
  sellerName                 String
  sellerTaxId                String    @default("")
  buyerName                  String
  buyerTaxId                 String    @default("")
  netAmount                  Decimal
  vatAmount                  Decimal
  grossAmount                Decimal
  currency                   String    @default("PLN")
  rawPayload                 String
  importedAsCostInvoiceId    String?
  importedAsRevenueInvoiceId String?
  syncSessionId              String?
  syncSession                KsefSyncSession? @relation(fields: [syncSessionId], references: [id], onDelete: SetNull)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  @@index([syncSessionId])
  @@index([issueDate])
}

/// Użytkownik aplikacji — Etap 1: tylko logowanie; role jako string pod przyszłe RBAC.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  /// Np. ADMIN — na start jedna rola; później bez migracji enumów.
  role         String   @default("ADMIN")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}
